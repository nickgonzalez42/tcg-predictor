# TCG Predictor — IP-only HTTP for now. When a domain lands, replace `:80`
# with the domain and Caddy handles TLS automatically.
# handle blocks are mutually exclusive — the SPA's try_files can't swallow
# /api/* (try_files is a rewrite and would otherwise run before the proxy).
:80 {
	encode gzip

	handle /api/* {
		reverse_proxy 127.0.0.1:5000
	}

	handle /card-images/* {
		reverse_proxy 127.0.0.1:5000
	}

	handle {
		root * /srv/tcg/client
		try_files {path} /index.html
		file_server
	}
}
